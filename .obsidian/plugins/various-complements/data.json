{
  "strategy": "default",
  "matchStrategy": "prefix",
  "fuzzyMatch": true,
  "minFuzzyMatchScore": 0.5,
  "maxNumberOfSuggestions": 8,
  "maxNumberOfWordsAsPhrase": 3,
  "minNumberOfCharactersTriggered": 1,
  "complementAutomatically": true,
  "delayMilliSeconds": 80,
  "disableSuggestionsInMathBlock": true,
  "disableSuggestionsInCodeBlock": true,
  "firstCharactersDisableSuggestions": ":/^",
  "showMatchStrategy": false,
  "showComplementAutomatically": false,
  "showIndexingStatus": false,
  "descriptionOnSuggestion": "Short",
  "hotkeys": {
    "select": [
      {
        "modifiers": [],
        "key": "Enter"
      }
    ],
    "up": [
      {
        "modifiers": [],
        "key": "ArrowUp"
      }
    ],
    "down": [
      {
        "modifiers": [],
        "key": "ArrowDown"
      }
    ]
  },
  "enableCurrentFileComplement": true,
  "currentFileMinNumberOfCharacters": 1,
  "enableCurrentVaultComplement": true,
  "currentVaultMinNumberOfCharacters": 3,
  "excludeCurrentVaultPathPrefixPatterns": ".obsidian,99 Assets,90 Archive",
  "excludeCurrentVaultPathGlobPatterns": [],
  "enableInternalLinkComplement": true,
  "suggestInternalLinkWithAlias": true,
  "preserveFirstLetterCaseOnInternalLink": true,
  "excludeSelfInternalLink": true,
  "excludeExistingInActiveFileInternalLinks": false,
  "updateInternalLinksOnSave": true,
  "enableFrontMatterComplement": true,
  "intelligentSuggestionPrioritization": {
    "enabled": true,
    "historyFilePath": "00 Home/Tasks/.various-complements-history.json",
    "prettyPrintHistoryFile": false,
    "maxDaysToKeepHistory": 30,
    "maxNumberOfHistoryToKeep": 1000
  },
  "disableOnMobile": false
}
